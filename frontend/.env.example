# ── Backend URL ───────────────────────────────────────────────────────────────
# Dev: leave unset — Vite proxies /api to localhost:3001
# Production: set to your Render backend URL (no trailing slash)
# VITE_API_URL=https://gitpulse-backend.onrender.com

