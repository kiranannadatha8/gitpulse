# ── Database ──────────────────────────────────────────────────────────────────
# Local dev:  postgresql://postgres:password@localhost:5432/gitpulse
# Production: provided by your managed DB (Railway, Supabase, Neon, etc.)
DATABASE_URL="postgresql://postgres:password@localhost:5432/gitpulse"

# ── AI / GitHub API keys ──────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
GITHUB_TOKEN="ghp_..."

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Dev callback URL:  http://localhost:3001/api/auth/github/callback
# Prod callback URL: https://your-backend.railway.app/api/auth/github/callback
GITHUB_CLIENT_ID="your-client-id"
GITHUB_CLIENT_SECRET="your-client-secret"

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Must be at least 32 characters. Use a different value for each environment.
SESSION_SECRET="replace-with-a-random-64-char-hex-string"

# ── URLs ──────────────────────────────────────────────────────────────────────
PORT=3001
# Dev:  http://localhost:5173   Prod: https://your-frontend.railway.app
FRONTEND_URL="http://localhost:5173"
# Dev:  http://localhost:3001   Prod: https://your-backend.railway.app
BACKEND_URL="http://localhost:3001"

# ── Observability ────────────────────────────────────────────────────────────
# Optional: Sentry DSN for error tracking. Leave unset to disable Sentry.
# SENTRY_DSN="https://xxx@oXXXX.ingest.sentry.io/YYYYYYY"
# Log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL="info"

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV="development"
